{
  "name": "watch-together",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm test && pnpm build",
    "dev:poc": "pnpm --filter @watch-together/poc-media-capture-livekit dev",
    "dev:poc:down": "pnpm --filter @watch-together/poc-media-capture-livekit dev:down",
    "test": "pnpm -r --if-present test"
  }
}
